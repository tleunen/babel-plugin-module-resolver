{
  "name": "babel-plugin-module-resolver",
  "version": "5.0.3",
  "description": "Module resolver plugin for Babel",
  "keywords": [
    "alias",
    "babel",
    "babel-plugin",
    "import",
    "mapping",
    "module",
    "rename",
    "require",
    "resolve",
    "resolver",
    "rewrite"
  ],
  "license": "MIT",
  "author": {
    "name": "Tommy Leunen",
    "email": "tommy.leunen@gmail.com",
    "url": "http://tommyleunen.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tleunen/babel-plugin-module-resolver.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "fmt": "vp fmt -c .oxfmtrc.json .",
    "fmt:check": "vp fmt --check -c .oxfmtrc.json .",
    "lint": "vp lint -c .oxlintrc.json .",
    "build": "vp pack",
    "check": "npm run fmt:check && npm run lint",
    "pretest": "npm run check",
    "test": "vp test run",
    "test:coverage": "vp test run --coverage",
    "test:watch": "vp test watch",
    "prepublishOnly": "npm run build",
    "release": "standard-version"
  },
  "dependencies": {
    "find-babel-config": "^2.1.2",
    "resolve": "^1.22.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@vitest/coverage-v8": "^4.1.0",
    "common-tags": "^1.8.2",
    "standard-version": "^9.5.0",
    "vite-plus": "^0.1.12"
  },
  "engines": {
    "node": ">=22"
  }
}
